# Supabase PostgreSQL (Connect → Transaction pooler, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Google AI — embeddings (uses your Google Cloud / AI Studio credits)
# Get key: https://aistudio.google.com/apikey
EMBEDDING_PROVIDER=google
GOOGLE_API_KEY=AIza...

# Optional: use OpenAI instead (set EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
# Free tier: smaller batches + longer pause reduces 429/503 during bulk embed
EMBEDDING_BATCH_SIZE=3
EMBEDDING_BATCH_DELAY_SECONDS=8
# Query embedding cache (Phase 3 — faster repeat searches)
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_DB=true
EMBEDDING_CACHE_MAX_ENTRIES=500
LLM_MODEL=gemini-2.0-flash-lite
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://juvenile-justice-intelligence-platf.vercel.app
